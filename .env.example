LOOKBACK_DAYS=3
# 최근 범위를 2일로 변경하려면 LOOKBACK_DAYS=2

# 소송번호/사건명 매칭이 애매할 때, CourtListener 도켓 후보 Top3를 리포트 표에 함께 표시
# (사람이 직접 후보를 보고 판단/보완할 수 있도록 도움)
SHOW_DOCKET_CANDIDATES=0

# (옵션) 표에서 긴 셀(도켓 후보 Top3, 최근 도켓 업데이트 3건)을 <details>/<summary>로 접어서 표시
COLLAPSE_LONG_CELLS=1

# (옵션) '기사 주소' 섹션을 <details>/<summary>로 접어서 표시
COLLAPSE_ARTICLE_URLS=1

# (옵션) BM25 알고리즘 기반 텍스트 유사도 중복 제거 활성화
BM25_SEMANTIC_DEDUP=1

# 이메일 전송 활성화 (1: 활성화, 0: 비활성화)
ENABLE_EMAIL_SENDER=0

